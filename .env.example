# Copy this file to .env.local for local development (see README.md "Quick start").
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time by Next.js —
# changing one requires a rebuild, not just a redeploy. See docs/known-issues.md.

# PayPal JS SDK client ID (sandbox or live, depending on environment)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEYS=

# Stripe webhook endpoint URL used by the donation flow
NEXT_PUBLIC_STRIPE_WEBHOOK_URL=

# Base URL of the NewWave4 backend API (Java Spring Boot)
NEXT_PUBLIC_NEWWAVE_API_URL=

# Optional: sub-path the app is served under (see next.config.ts basePath/assetPrefix). Leave empty for root.
NEXT_PUBLIC_BASE_PATH=
